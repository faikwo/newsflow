# NewsFlow Environment — Security-Hardened Configuration
# Copy this to .env and customize for your deployment

# ── SECURITY (CRITICAL) ──────────────────────────────────────────────────────
# This key signs all login tokens. MUST be set to a strong random value.
# Generate one with: openssl rand -hex 32
# The app will REFUSE TO START if this is not set or is still the default.
SECRET_KEY=

# Allowed CORS origins for API requests (comma-separated)
# For production, set this to your actual domain(s):
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# For development, localhost is used by default
ALLOWED_ORIGINS=http://localhost:3000

# ── Network ───────────────────────────────────────────────────────────────────
# Port to expose the app on (access via http://YOUR_IP:PORT)
PORT=3000

# ── Ollama (Optional) ─────────────────────────────────────────────────────────
# Set this to bypass the UI settings and hardwire your Ollama server URL.
# Example: OLLAMA_URL=http://10.10.1.130:11434
OLLAMA_URL=
